#!/bin/bash
# 卸载回调：清理残留进程

LOG_FILE="${TRIM_PKGVAR}/info.log"
log_msg() {
    [ -n "${LOG_FILE}" ] && [ -d "$(dirname ${LOG_FILE})" ] && \
        echo "$(date '+%Y-%m-%d %H:%M:%S') - [uninstall] $1" >> ${LOG_FILE} 2>/dev/null
}

# 杀残留 node 进程
pkill -KILL -u proc_guardian -f "node server.js" 2>/dev/null || true

# 杀占用 8877 的进程
pid_8877=$(ss -tlnp 2>/dev/null | grep ':8877 ' | grep -oP 'pid=\K[0-9]+' | head -1)
[ -n "${pid_8877}" ] && kill -KILL "${pid_8877}" 2>/dev/null || true

log_msg "Uninstall cleanup done"
exit 0
